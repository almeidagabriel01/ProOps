rules_version = '2';

/**
 * Firestore Security Rules - Multi-Tenant ERP SaaS
 *
 * SECURITY ARCHITECTURE:
 * 1. DENY BY DEFAULT: All paths not explicitly matched are denied.
 * 2. CLOUD FUNCTIONS AUTHORITY: Complex logic and critical writes (billing, quotas) MUST go through Cloud Functions.
 * 3. TENANT ISOLATION: Users can ONLY access data tagged with their `tenantId`.
 * 4. ROOT COLLECTIONS: Data attempts to be flat (proposals, clients) rather than nested, enforcing `tenantId` check on every read.
 */

service cloud.firestore {
  match /databases/{database}/documents {

    // ============================================
    // HELPER FUNCTIONS
    // ============================================

    /**
     * Check if user is authenticated
     */
    function isAuthenticated() {
      return request.auth != null;
    }

    /**
     * Check if authenticated user is the document owner
     */
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    /**
     * Claims-based tenant source (trusted token claim)
     */
    function getAuthTenantId() {
      return isAuthenticated() ? request.auth.token.get('tenantId', '') : '';
    }

    /**
     * Claims-based role source (trusted token claim)
     */
    function getAuthRole() {
      return isAuthenticated() ? request.auth.token.get('role', '') : '';
    }

    /**
     * User-document tenant fallback for cases where custom claims are stale.
     */
    function getUserDocTenantId() {
      return isAuthenticated()
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             ? get(/databases/$(database)/documents/users/$(request.auth.uid))
                 .data.get('tenantId',
                           get(/databases/$(database)/documents/users/$(request.auth.uid))
                             .data.get('companyId', ''))
             : '';
    }

    /**
     * Effective tenant source: prefer trusted claim, fallback to user document.
     */
    function getEffectiveTenantId() {
      let claimTenantId = getAuthTenantId();
      return claimTenantId != '' ? claimTenantId : getUserDocTenantId();
    }

    /**
     * User-document role fallback for stale claims.
     */
    function getUserDocRole() {
      return isAuthenticated()
             && exists(/databases/$(database)/documents/users/$(request.auth.uid))
             ? get(/databases/$(database)/documents/users/$(request.auth.uid))
                 .data.get('role', '')
             : '';
    }

    /**
     * Firestore role fallback for superadmin checks.
     * This avoids hard failures when production tokens are temporarily stale
     * while still requiring an authenticated, server-controlled user document.
     *
     * Tests pre-seed users/{uid} in beforeEach so exists() always finds the
     * doc; in production users/{uid} is created on signup.
     */
    function hasSuperAdminRoleInUserDoc() {
      return isAuthenticated()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid))
           .data.get('role', '') in ['superadmin', 'SUPERADMIN'];
    }

    /**
     * Claims-based master source (trusted token claim)
     */
    function getAuthMasterId() {
      return isAuthenticated() ? request.auth.token.get('masterId', '') : '';
    }

    /**
     * Bootstrap tenant used during initial registration before claims are minted.
     */
    function isBootstrapTenant(tenantId) {
      return isAuthenticated() && tenantId == 'tenant_' + request.auth.uid;
    }

    /**
     * Check if the user belongs to the tenant that owns the resource.
     */
    function belongsToTenant(resourceTenantId) {
       return isAuthenticated()
            && getEffectiveTenantId() != ''
              && resourceTenantId != ''
            && getEffectiveTenantId() == resourceTenantId;
    }

    /**
     * Tenant admin roles allowed to manage tenant-scoped records.
     */
    function hasTenantAdminRole() {
      return isAuthenticated()
             && (
               getAuthRole() in ['admin', 'ADMIN', 'master', 'MASTER', 'wk', 'WK']
               || getUserDocRole() in ['admin', 'ADMIN', 'master', 'MASTER', 'wk', 'WK']
             );
    }

    /**
     * Resolve tenant from resource data with legacy companyId fallback.
     */
    function tenantFromData(data) {
      return data.get('tenantId', data.get('companyId', ''));
    }

    /**
     * Self-registration user document validation.
     */
    function isValidSelfRegistrationUserCreate(userId) {
      let bootstrapTenant = 'tenant_' + request.auth.uid;
      return isOwner(userId)
             && request.resource.data.keys().hasOnly([
               'name',
               'email',
               'photoUrl',
               'phoneNumber',
               'role',
               'tenantId',
               'companyId',
               'onboarding',
               'createdAt',
               'updatedAt',
             ])
             && request.resource.data.get('role', '') in ['free', 'FREE']
             && request.resource.data.get('tenantId', '') == bootstrapTenant
             && request.resource.data.get('companyId', bootstrapTenant) == bootstrapTenant;
    }

    /**
     * True when the caller authenticated with a second factor (TOTP MFA).
     * Firebase sets firebase.sign_in_second_factor on the ID token after an
     * MFA sign-in; it is null for single-factor sessions.
     */
    function hasMfa() {
      return isAuthenticated()
             && request.auth.token.firebase.sign_in_second_factor != null;
    }

    /**
     * Check if user is a super admin.
     * Super admins have full read access to all tenant data for administration.
     * MFA (second factor) is REQUIRED — a super admin without an MFA session
     * loses client-SDK privileged access (data flows go through the backend
     * Admin SDK). This is intentional hardening; see SUPERADMIN_MFA_REQUIRED.
     */
    function isSuperAdmin() {
      return isAuthenticated()
             && hasMfa()
             && (getAuthRole() in ['superadmin', 'SUPERADMIN']
                 || hasSuperAdminRoleInUserDoc());
    }

    /**
     * Returns the subscriptionStatus claim from the token, or '' if absent.
     * Returns '' (not blocked) when the claim hasn't been set yet (backwards compat
     * during claim migration rollout — tokens without this claim are treated as active).
     */
    function getAuthSubscriptionStatus() {
      return isAuthenticated() ? request.auth.token.get('subscriptionStatus', '') : '';
    }

    /**
     * Returns true when the tenant's subscription allows data reads.
     *
     * Fast-path: active/trialing/free claims are trusted from the JWT (updated
     * within seconds by billing-claims.ts) — no Firestore read needed.
     * For ambiguous states (claim absent or 'past_due'), reads the authoritative
     * tenant document to catch stale-claim discrepancies (e.g., claim says
     * past_due but Firestore already shows canceled after an immediate cancel).
     *
     * tenants/{id} and users/{id} are intentionally excluded from this check
     * so the subscription-blocked page can still read billing state.
     */
    function tenantSubscriptionAllowsRead(resourceTenantId) {
      let claimStatus = getAuthSubscriptionStatus();
      let isAllowedClaim = claimStatus == 'active' || claimStatus == 'trialing' || claimStatus == 'free';
      let isBlockedClaim = claimStatus in ['canceled', 'cancelled', 'unpaid', 'inactive', 'payment_failed'];
      // isAllowedClaim/isBlockedClaim: pure string comparisons, safe as let bindings.
      // get() is placed inside an exists() && ... chain: && short-circuits reliably,
      // so get() is never evaluated on a non-existent document even if || does not
      // short-circuit (emulator v1.21+ does not short-circuit || consistently).
      return !(getAuthRole() in ['free', 'FREE'])
             && (isAllowedClaim
                 || (!isBlockedClaim
                     && isAuthenticated()
                     && resourceTenantId != ''
                     && (!exists(/databases/$(database)/documents/tenants/$(resourceTenantId))
                         || (exists(/databases/$(database)/documents/tenants/$(resourceTenantId))
                             && !(string(get(/databases/$(database)/documents/tenants/$(resourceTenantId)).data.get('subscriptionStatus', '')).lower()
                                  in ['canceled', 'cancelled', 'unpaid', 'inactive', 'payment_failed'])))));
    }

    /**
     * Whitelist for allowing specific field updates.
     */
    function onlyUpdatesFields(allowedFields) {
      let affectedKeys = request.resource.data.diff(resource.data).affectedKeys();
      return affectedKeys.hasOnly(allowedFields);
    }

    // ============================================
    // USERS COLLECTION
    // ============================================

    match /users/{userId} {
      // READ: Own profile, Master of this user, Admin of same tenant, Member reading their Master, or Super Admin
      // Using resource.data.get() with default to avoid null errors for non-existent docs
      allow read: if isOwner(userId)
                  || isSuperAdmin()
                  || (isAuthenticated() && resource.data.get('masterId', '') == request.auth.uid)
                  || (hasTenantAdminRole() && belongsToTenant(tenantFromData(resource.data)))
                  || (isAuthenticated() && getAuthMasterId() == userId);

      // CREATE: Allowed for self-registration (user creating their own document)
      allow create: if isValidSelfRegistrationUserCreate(userId);

      // UPDATE: Owner can update profile info, but NOT sensitive roles/ids.
      // Super admin can update any field for tenant management.
      allow update: if isSuperAdmin()
                    || (isOwner(userId)
                        && onlyUpdatesFields(['name', 'photoUrl', 'phoneNumber', 'updatedAt'])
                        && !request.resource.data.diff(resource.data).affectedKeys()
                            .hasAny(['role', 'masterId', 'tenantId', 'companyId',
                                     'subscription', 'usage', 'stripeCustomerId', 'stripeSubscriptionId']));

      // DELETE: Blocked for regular users. Super admin can delete for tenant cleanup.
      allow delete: if isSuperAdmin();

      // PERMISSIONS SUBCOLLECTION: User can read their own permissions, their Master can, or Super Admin
      match /permissions/{permissionId} {
        allow read: if isOwner(userId)
                    || (isAuthenticated() && get(/databases/$(database)/documents/users/$(userId)).data.get('masterId', '') == request.auth.uid)
                    || isSuperAdmin();
        allow write: if false; // Only Cloud Functions can manage permissions
      }
    }

    // ============================================
    // TENANT RESOURCES (Root Collections)
    // ============================================
    // Pattern: Read allowed if user's tenantId matches resource's tenantId AND
    //          their subscription is not in a terminal blocked status.
    // Writes blocked (Cloud Functions only) or restricted.

    // PROPOSALS
    match /proposals/{proposalId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false; // Managed by Cloud Functions (limits, validation)
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }

    // CLIENTS
    match /clients/{clientId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false; // Managed by Cloud Functions (limits)
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }

    // PRODUCTS
    match /products/{productId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false; // Managed by Cloud Functions (limits)
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }

    // SERVICES
    match /services/{serviceId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false; // Managed by Cloud Functions (limits)
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }

    // TRANSACTIONS (Financial)
    match /transactions/{transactionId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false; // Managed by Cloud Functions (calculations)
    }

    // WALLETS
    match /wallets/{walletId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false; // Managed by Cloud Functions
    }

    // WALLET TRANSACTIONS (audit log)
    match /wallet_transactions/{transactionId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false; // Managed by Cloud Functions
    }

    // WALLET CASCADE JOBS (live progress for async wallet rename cascade)
    // Tenant members may read their tenant's jobs so the UI can show
    // real-time progress via onSnapshot. Writes are Admin SDK only.
    match /wallet_cascade_jobs/{jobId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId));
      allow write: if false; // Managed by Cloud Functions trigger
    }

    // SISTEMAS (Automation)
    match /sistemas/{sistemaId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false;
    }

    // AMBIENTES (Automation)
    match /ambientes/{ambienteId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false;
    }

    // PROPOSAL TEMPLATES
    match /proposal_templates/{templateId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false;
    }

    // CUSTOM FIELDS
    match /custom_fields/{fieldId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false;
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }

    // CUSTOM OPTIONS (Legacy)
    match /custom_options/{optionId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false;
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }

    // OPTIONS (Dynamic Selects)
    match /options/{optionId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false;
      allow delete: if isSuperAdmin(); // Super admin can delete for tenant cleanup
    }

    // ADDONS
    match /addons/{addonId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false; // Managed by Stripe Webhooks
    }

    // KANBAN STATUSES (Custom kanban columns per tenant)
    match /kanban_statuses/{statusId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false; // Managed by Cloud Functions
    }

    // CALENDAR EVENTS (tenant-scoped, member sees own events, admin sees tenant events)
    match /calendar_events/{eventId} {
      allow read: if isSuperAdmin()
                  || (isAuthenticated()
                      && belongsToTenant(resource.data.tenantId)
                      && tenantSubscriptionAllowsRead(resource.data.tenantId)
                      && (resource.data.get('ownerUserId', '') == request.auth.uid
                          || hasTenantAdminRole()));
      allow write: if false; // Managed by Cloud Functions
    }

    // ============================================
    // SYSTEM COLLECTIONS
    // ============================================

    // COMPANIES (Legacy/Core Tenant Info)
    // Not subscription-gated: needed by the subscription-blocked page to read billing context.
    match /companies/{companyId} {
      // Only members of the company can view its details
      allow read: if isSuperAdmin()
                  || (isAuthenticated()
                      && (companyId == getEffectiveTenantId()
                          || companyId == request.auth.token.get('companyId', '')));
      allow write: if false;
    }

    // TENANTS (New Tenant Info)
    // Not subscription-gated: needed by the subscription-blocked page to read billing/subscription state.
    match /tenants/{tenantId} {
      // Allow read if: super admin, user's tenantId matches, OR tenant ID matches the UID pattern (fallback for new users)
      allow read: if isSuperAdmin()
                  || belongsToTenant(tenantId)
                  || isBootstrapTenant(tenantId);
      // CREATE: Super admin can create any tenant, users can only create their own (self-registration)
      allow create: if isSuperAdmin()
                    || (isBootstrapTenant(tenantId)
                        && request.resource.data.get('tenantId', tenantId) == tenantId
                        && request.resource.data.keys().hasOnly([
                          'tenantId',
                          'name',
                          'slug',
                          'primaryColor',
                          'logoUrl',
                          'niche',
                          'createdAt',
                          'updatedAt',
                        ]));
      // UPDATE: Super admin can update any field, tenant owner (master) can update safe fields
      allow update: if isSuperAdmin()
                    || (isAuthenticated()
                        && belongsToTenant(tenantId)
                        && hasTenantAdminRole()
                        && request.resource.data.get('tenantId', tenantId) == tenantId
                        && resource.data.get('tenantId', tenantId) == request.resource.data.get('tenantId', tenantId)
                        && onlyUpdatesFields(['name', 'niche', 'primaryColor', 'logoUrl', 'updatedAt']));
      // DELETE: Only super admin can delete tenants
      allow delete: if isSuperAdmin();

      // MP OAuth one-time codes — written only by Admin SDK (backend)
      match /mpOAuthCodes/{codeHash} {
        allow read, write: if false;
      }
    }

    // PURCHASED ADDONS
    match /purchased_addons/{addonId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false; // Managed by Stripe Webhooks
    }

    // PLANS (Public/Reference - needed by PlanService.getPlanById on frontend)
    match /plans/{planId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // PAGES (Reference)
    match /pages/{pageId} {
      allow read: if isAuthenticated();
      allow write: if false;
    }

    // SHARED PROPOSALS - Acesso público via token
    // Cloud Functions validam token e expiração
    match /shared_proposals/{shareId} {
      allow read: if false; // Public access only via backend token-validation endpoint
      allow write: if false; // Apenas Cloud Functions
    }

    // SPREADSHEETS
    match /spreadsheets/{spreadsheetId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.get('tenantId', '')) && tenantSubscriptionAllowsRead(resource.data.get('tenantId', '')));
      allow create: if isSuperAdmin()
                    || (isAuthenticated()
                        && hasTenantAdminRole()
                        && request.resource.data.get('tenantId', '') != ''
              && request.resource.data.get('tenantId', '') == getEffectiveTenantId());
      allow update: if isSuperAdmin()
                    || (isAuthenticated()
                        && hasTenantAdminRole()
                        && belongsToTenant(resource.data.get('tenantId', ''))
                        && request.resource.data.get('tenantId', '') == resource.data.get('tenantId', '')
              && request.resource.data.get('tenantId', '') == getEffectiveTenantId());
      allow delete: if isSuperAdmin()
                    || (isAuthenticated()
                        && hasTenantAdminRole()
                        && belongsToTenant(resource.data.get('tenantId', '')));
    }

    // NOTIFICATIONS - Acesso restrito ao tenant
    match /notifications/{notificationId} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(resource.data.tenantId) && tenantSubscriptionAllowsRead(resource.data.tenantId));
      allow write: if false; // Apenas Cloud Functions
    }

    // ============================================
    // AI ASSISTANT (Lia)
    // ============================================

    // AI Usage — monthly counters per tenant
    // Read: authenticated tenant members can see their usage; superadmin has read-only access
    // Write: only backend (Admin SDK) — incremented atomically by usage-tracker.ts
    match /tenants/{tenantId}/aiUsage/{month} {
      allow read: if isSuperAdmin() || (isAuthenticated() && belongsToTenant(tenantId) && tenantSubscriptionAllowsRead(tenantId));
      allow write: if false;
    }

    // AI Conversations — chat history per session
    // get: user can only fetch their own session doc (uid enforced on resource); superadmin can read any
    // list: tenant-scoped only; client query must include where("uid","==",uid) for user isolation
    // Write: only backend (Admin SDK) — managed by conversation-store.ts
    match /tenants/{tenantId}/aiConversations/{sessionId} {
      allow get: if isSuperAdmin()
                 || (isAuthenticated()
                     && belongsToTenant(tenantId)
                     && tenantSubscriptionAllowsRead(tenantId)
                     && (resource == null || resource.data.uid == request.auth.uid));
      // list: require uid equality on every returned document so a query without
      // a uid filter (or one with another user's uid) is automatically rejected.
      allow list: if isSuperAdmin()
                  || (isAuthenticated()
                      && belongsToTenant(tenantId)
                      && tenantSubscriptionAllowsRead(tenantId)
                      && resource.data.uid == request.auth.uid);
      allow write: if false;
    }

    // ============================================
    // BACKEND-ONLY COLLECTIONS
    // Managed exclusively by Cloud Functions (admin SDK).
    // Explicitly denied to prevent accidental client access.
    // ============================================

    match /phoneNumberIndex/{phone} {
      allow read, write: if false;
    }

    match /whatsappUsage/{tenantId} {
      allow read, write: if false;
      match /months/{month} {
        allow read, write: if false;
      }
    }

    match /whatsappSessions/{sessionId} {
      allow read, write: if false;
    }

    match /whatsappRateLimit/{limitId} {
      allow read, write: if false;
    }

    match /whatsappLogs/{logId} {
      allow read, write: if false;
    }

    match /stripe_events/{eventId} {
      allow read, write: if false;
    }

    match /payout_attempts/{id} {
      allow read, write: if false; // backend-only via Admin SDK
    }

    // EMAIL AUDIT — written exclusively by Cloud Functions (Admin SDK)
    // Super admins can read for operational monitoring; no tenant-level access needed
    match /email_audit/{auditId} {
      allow read: if isSuperAdmin();
      allow write: if false;
    }

    match /calendar_integrations/{integrationId} {
      allow read, write: if false;
    }

    match /calendar_oauth_states/{stateId} {
      allow read, write: if false;
    }

    // SECURITY OBSERVABILITY — written exclusively by Cloud Functions (Admin SDK).
    // The audit trail is read through the backend (GET /admin/audit-events), never
    // via the client SDK. Denied here explicitly for clarity (also covered by the
    // catch-all below).
    match /security_audit_events/{eventId} {
      allow read, write: if false;
    }

    match /security_metrics/{windowId} {
      allow read, write: if false;
    }

    match /security_metrics_tenants/{docId} {
      allow read, write: if false;
    }

    // WhatsApp OTP 2FA challenges (hashed code + TTL + attempt counters).
    // Written and verified exclusively by Cloud Functions (Admin SDK).
    match /mfaOtpChallenges/{uid} {
      allow read, write: if false;
    }

    // MFA recovery (backup) codes — hashed, single-use. Written, read and
    // consumed exclusively by Cloud Functions (Admin SDK). Never client-visible.
    match /mfaRecoveryCodes/{uid} {
      allow read, write: if false;
    }

    // ============================================
    // CATCH-ALL
    // ============================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
