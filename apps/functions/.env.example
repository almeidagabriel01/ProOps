# ================================================================
# ProOps — Backend / Firebase Functions
# Copie para functions/.env.erp-softcode (dev) ou
#          functions/.env.erp-softcode-prod (prod)
# NUNCA commitar arquivos com valores reais.
# ================================================================

# ── Stripe ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── WhatsApp (Meta Business API) ────────────────────────────────
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# ── Segurança interna ────────────────────────────────────────────
# Usado para autenticar chamadas de cron jobs internos
CRON_SECRET=

# ── Firebase Admin SDK ──────────────────────────────────────────
# Obtido em: Firebase Console → Configurações do projeto → Contas de serviço
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@projeto.iam.gserviceaccount.com

# ── Sentry (opcional mas recomendado em produção) ────────────────
# DSN disponível em: sentry.io → Projeto → Settings → Client Keys
# Sem esta variável o Sentry não inicializa (sem erros nem warnings).
SENTRY_DSN=

# ── Observabilidade (opcional) ───────────────────────────────────
# false = desativa escrita de métricas/audit no Firestore
SECURITY_OBSERVABILITY_ENABLED=true

# ── Rate Limiting ────────────────────────────────────────────────
# Padrão: 240 req/min por usuário (rotas protegidas)
RATE_LIMIT_PROTECTED_MAX=240
RATE_LIMIT_PROTECTED_WINDOW_MS=60000

# Padrão: 120 req/min por usuário (rotas privilegiadas: admin, stripe)
RATE_LIMIT_PRIVILEGED_MAX=120
RATE_LIMIT_PRIVILEGED_WINDOW_MS=60000

# ── CORS ─────────────────────────────────────────────────────────
# Origens permitidas separadas por vírgula (sem espaços)
# Exemplo: https://app.empresa.com,https://www.empresa.com
ALLOWED_CORS_ORIGINS=

# ── Timeouts ─────────────────────────────────────────────────────
PROTECTED_ROUTE_TIMEOUT_MS=20000
PROTECTED_PDF_ROUTE_TIMEOUT_MS=120000

# ── Mercado Pago (Pagamento Online) ─────────────────────────
MERCADOPAGO_APP_ID=
MERCADOPAGO_CLIENT_SECRET=
MERCADOPAGO_OAUTH_REDIRECT_URI=
MERCADOPAGO_STATE_SECRET=
MERCADOPAGO_WEBHOOK_SECRET=
# Platform-level access token used by mercadopagoWebhook.ts when resolving
# Checkout Pro payments where the direct payment_attempts lookup by mpPaymentId
# is empty. Obtained from the ProOps MP app credentials page (NOT a tenant
# OAuth token). See MPWH-03 in .planning/phases/23-mp-webhook-hardening/.
MERCADOPAGO_PLATFORM_ACCESS_TOKEN=
# Sandbox overrides — usados quando o tenant está conectado via OAuth com conta @testuser.com.
# Devem ser credenciais TEST- de uma App MP do integrador rodando em sandbox.
# Sem estas envs, pagamento de cartão para tenants sandbox usa APP_USR- do vendedor e falha
# com error code 2034 (Invalid users involved) pois MP trata APP_USR- de test seller como live.
MERCADOPAGO_SANDBOX_PUBLIC_KEY=
MERCADOPAGO_SANDBOX_ACCESS_TOKEN=
# Email do Test User Comprador criado via POST /users/test (site_id:MLB, profile:buyer).
# Quando configurado, é pré-preenchido no Card Payment Brick em sandbox.
# Sem esta var, o campo de email fica visível com instruções para o testador preencher.
MERCADOPAGO_SANDBOX_BUYER_EMAIL=

# ── IA ───────────────────────────────────────────────────────
# Produção: apenas GEMINI_API_KEY
GEMINI_API_KEY=
# Desenvolvimento local: GROQ_API_KEY ativa o provider Groq (llama-3.3-70b-versatile)
# Se definido, Groq é usado no lugar do Gemini. Obtenha em console.groq.com.
GROQ_API_KEY=

# ── Planos / Deferral ────────────────────────────────────────
# "false" desativa o adiamento de downgrades para o fim do período
# Padrão: "true" (downgrades são agendados, não aplicados imediatamente)
WHATSAPP_DEFER_DOWNGRADE=true

# ── Billing cache cross-layer invalidation ───────────────────
# Shared with Next.js frontend — must match BILLING_CACHE_INVALIDATION_SECRET in .env.local
BILLING_CACHE_INVALIDATION_SECRET=your-random-secret-here
APP_URL=https://your-app.vercel.app

# ── Email transacional (Resend) ──────────────────────────────────────────────
# Obtenha em: resend.com → API Keys
# Verificar domínio proops.com.br em: resend.com → Domains (SPF + DKIM)
RESEND_API_KEY=re_...
EMAIL_FROM="ProOps <noreply@proops.com.br>"