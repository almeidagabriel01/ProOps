# ================================================================
# ProOps — Backend / Firebase Functions
# Copie para functions/.env.erp-softcode (dev) ou
#          functions/.env.erp-softcode-prod (prod)
# NUNCA commitar arquivos com valores reais.
# ================================================================

# ── Stripe ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── WhatsApp (Meta Business API) ────────────────────────────────
WHATSAPP_APP_SECRET=
WHATSAPP_VERIFY_TOKEN=

# ── WhatsApp OTP 2FA (método alternativo de verificação em dois fatores) ──
# Segredo HMAC para hashear os códigos OTP. Gere com: openssl rand -hex 32.
OTP_SECRET=
# TTL do código OTP em segundos (default 300 = 5 min).
OTP_TTL_SECONDS=300
# Máximo de tentativas de verificação antes de bloquear o desafio (default 3).
OTP_MAX_ATTEMPTS=3
# Cooldown mínimo entre reenvios de OTP, em segundos (default 60).
OTP_RESEND_COOLDOWN_SECONDS=60
# Máximo de envios de OTP por hora por usuário (default 5).
OTP_MAX_SENDS_PER_HOUR=5
# Nome do template de Autenticação aprovado na Meta (categoria Authentication).
WHATSAPP_OTP_TEMPLATE_NAME=
# Idioma do template (default pt_BR).
WHATSAPP_OTP_TEMPLATE_LANG=pt_BR

# ── Segurança interna ────────────────────────────────────────────
# Usado para autenticar chamadas de cron jobs internos
CRON_SECRET=

# ── Firebase Admin SDK ──────────────────────────────────────────
# Obtido em: Firebase Console → Configurações do projeto → Contas de serviço
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@projeto.iam.gserviceaccount.com

# ── Sentry (opcional mas recomendado em produção) ────────────────
# DSN disponível em: sentry.io → Projeto → Settings → Client Keys
# Sem esta variável o Sentry não inicializa (sem erros nem warnings).
SENTRY_DSN=

# ── Observabilidade (opcional) ───────────────────────────────────
# false = desativa escrita de métricas/audit no Firestore
SECURITY_OBSERVABILITY_ENABLED=true
# Retenção (dias) dos eventos em security_audit_events. Default 365, min 90, max 730.
SECURITY_AUDIT_RETENTION_DAYS=365

# ── Super Admin (LGPD / segurança) ───────────────────────────────
# Allowlist de super admins (emails e/ou uids, separados por vírgula).
# VAZIO = allowlist NÃO é aplicada (ninguém é rebaixado). Quando preenchida,
# super admins fora da lista são rejeitados (403 FORBIDDEN_SUPERADMIN_NOT_ALLOWLISTED).
SUPERADMIN_ALLOWLIST=
# Kill-switch do MFA TOTP obrigatório para super admin. Default false.
# Só defina "true" DEPOIS de enrolar MFA na conta operadora (evita lockout).
# Quando "true", super admin sem segundo fator recebe 403 SUPERADMIN_MFA_REQUIRED.
SUPERADMIN_MFA_REQUIRED=false

# ── Google Calendar — criptografia do refresh token (Cloud KMS) ──
# Os refresh tokens OAuth do Google Calendar são criptografados em repouso via
# Cloud KMS. A service account do Cloud Run precisa de
# roles/cloudkms.cryptoKeyEncrypterDecrypter na chave.
# Opção 1 — nome completo do recurso da chave:
CALENDAR_TOKEN_KMS_KEY=
# Opção 2 — partes individuais (ignoradas se CALENDAR_TOKEN_KMS_KEY estiver setado;
# o projeto usa GCLOUD_PROJECT; location default southamerica-east1):
CALENDAR_TOKEN_KMS_LOCATION=southamerica-east1
CALENDAR_TOKEN_KMS_KEYRING=
CALENDAR_TOKEN_KMS_KEY_ID=

# ── Rate Limiting ────────────────────────────────────────────────
# Padrão: 240 req/min por usuário (rotas protegidas)
RATE_LIMIT_PROTECTED_MAX=240
RATE_LIMIT_PROTECTED_WINDOW_MS=60000

# Padrão: 120 req/min por usuário (rotas privilegiadas: admin, stripe)
RATE_LIMIT_PRIVILEGED_MAX=120
RATE_LIMIT_PRIVILEGED_WINDOW_MS=60000

# ── CORS ─────────────────────────────────────────────────────────
# Origens permitidas separadas por vírgula (sem espaços)
# Exemplo: https://app.empresa.com,https://www.empresa.com
ALLOWED_CORS_ORIGINS=

# ── Proxy de imagem (bucket-pinning) ─────────────────────────────
# O endpoint /v1/aux/proxy-image só busca imagens dos buckets do projeto.
# Se VAZIO, deriva os defaults do Firebase a partir de GCLOUD_PROJECT
# (<projeto>.appspot.com e <projeto>.firebasestorage.app). Sobrescreva apenas
# se usar um bucket com nome custom (lista separada por vírgula).
PROXY_IMAGE_ALLOWED_BUCKETS=

# ── Timeouts ─────────────────────────────────────────────────────
PROTECTED_ROUTE_TIMEOUT_MS=20000
PROTECTED_PDF_ROUTE_TIMEOUT_MS=120000

# ── Asaas (Pagamento Online — PIX e Boleto) ─────────────────
# Chave mestre da conta ProOps no Asaas. Usada para criar subcontas de tenants.
# Obtida em: sandbox.asaas.com (sandbox) ou asaas.com (produção) → Minha Conta → Integrações → API
ASAAS_MASTER_API_KEY=$aact_sandbox_...
ASAAS_MASTER_API_KEY_PROD=$aact_prod_...

# ── IA ───────────────────────────────────────────────────────
# Produção: apenas GEMINI_API_KEY
GEMINI_API_KEY=
# Desenvolvimento local: GROQ_API_KEY ativa o provider Groq (llama-3.3-70b-versatile)
# Se definido, Groq é usado no lugar do Gemini. Obtenha em console.groq.com.
GROQ_API_KEY=

# ── Planos / Deferral ────────────────────────────────────────
# "false" desativa o adiamento de downgrades para o fim do período
# Padrão: "true" (downgrades são agendados, não aplicados imediatamente)
WHATSAPP_DEFER_DOWNGRADE=true

# ── Billing cache cross-layer invalidation ───────────────────
# Shared with Next.js frontend — must match BILLING_CACHE_INVALIDATION_SECRET in .env.local
BILLING_CACHE_INVALIDATION_SECRET=your-random-secret-here
APP_URL=https://your-app.vercel.app

# ── Email transacional (Resend) ──────────────────────────────────────────────
# Obtenha em: resend.com → API Keys
# Verificar domínio proops.com.br em: resend.com → Domains (SPF + DKIM)
RESEND_API_KEY=re_...
# Sender — usar `noreply@` no From (convenção) + Reply-To real abaixo.
EMAIL_FROM="ProOps <noreply@proops.com.br>"
# Reply-To real e monitorado — recebe respostas dos usuários e melhora reputação
EMAIL_REPLY_TO="gestao@proops.com.br"
# (OPCIONAL) Mailto pro header List-Unsubscribe. Se setado, exige que a
# caixa exista e responda — bounce no unsubscribe machuca mais do que omitir.
# Em desenvolvimento, deixe vazio. Em prod, só ative se tiver a caixa criada.
# EMAIL_UNSUBSCRIBE_MAILTO="unsubscribe@proops.com.br"
# (OPCIONAL) Destinatário dos emails internos de lifecycle (cadastro/plano).
# Default: gestao@proops.com.br. Em dev, aponte para uma caixa de teste.
# INTERNAL_NOTIFY_EMAIL=
# Cloudflare Turnstile — bot protection for the public signup contact-validation
# endpoint (/v1/validation/contact). Secret key from the Turnstile dashboard.
# If unset, captcha verification is skipped (dev/CI). REQUIRED in production.
TURNSTILE_SECRET_KEY=
# (OPCIONAL) Sobrescreve o limite por IP/min do endpoint de validação (default 60).
# RATE_LIMIT_VALIDATION_MAX=60

# ── Recuperação de 2FA (MFA) via recovery code ──────
# A recuperação do TOTP reautentica a senha via REST do Identity Platform
# (accounts:signInWithPassword), que exige a chave web PÚBLICA do Firebase.
# Reuse a mesma NEXT_PUBLIC_FIREBASE_API_KEY do frontend — ela precisa estar
# disponível para o backend (não crie uma env/secret nova).
NEXT_PUBLIC_FIREBASE_API_KEY=

# ── Zoom (videochamada da demonstração em /agendar) ──────────────────────────
# App "Server-to-Server OAuth" no Zoom Marketplace, escopo meeting:write:admin.
# Se vazio, o agendamento usa uma sala Jitsi como fallback (não quebra).
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=


# ── Freshness de custom claims no middleware de auth ─────────────────────────
# auto (default): busca claims frescas via getUser() só quando o token tem
#   claims incompletas, role FREE ou SUPERADMIN — corta 1 chamada externa por
#   request no hot path. always: comportamento legado (getUser em toda request).
# AUTH_CLAIMS_FRESHNESS=auto

# ── Rate limiting distribuído (Upstash Redis) ────────────────────────────────
# Ligar quando instâncias sustentadas >= 3 (ver docs/scalability-runbook.md).
# Todos os limiters HTTP respeitam estas vars; fail-open se o Redis cair.
# RATE_LIMIT_STORE=redis
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
